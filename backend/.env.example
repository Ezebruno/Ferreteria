# Database Configuration (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Redis & Celery (optional, for async tasks)
REDIS_URL=redis://127.0.0.1:6379/0

# Django Core
SECRET_KEY=generate-a-secure-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Security (Set to True in production with SSL)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# CORS & CSRF (comma-separated list of frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:4200,https://your-frontend.vercel.app

# Admin superuser (auto-created on first migrate)
DJANGO_ADMIN_EMAIL=admin@ferre.com
DJANGO_ADMIN_PASSWORD=your-secure-password

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=http://your-domain.com/api/integrations/mercadopago/webhook/
MP_APP_ID=
MP_CLIENT_SECRET=

# Mercado Libre
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=http://your-domain.com/admin/meli/

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
