# Database Configuration
DB_NAME=ferre-db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# Redis & Celery
REDIS_URL=redis://127.0.0.1:6379/0

# Django Core
SECRET_KEY=generate-a-secure-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,ferreteria-production-fc73.up.railway.app

# Security (Set to True in production with SSL)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200,https://ferreteria-4n8s.vercel.app

# Integrations (Global Defaults - Better to use IntegrationConfig model per tenant)
MP_ACCESS_TOKEN=
MP_WEBHOOK_URL=http://your-domain.com/api/integrations/mercadopago/webhook/

MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
